# =========================
# Python / Flask
# =========================
# Entornos
.venv/
venv/
ENV/
env/
ambiente_desarrollo
*.virtualenv

# Cachés / bytecode
__pycache__/
*.py[cod]
*$py.class

# Build / distribución
dist/
build/
*.egg-info/
.eggs/

# Cobertura / caches / tmp
.coverage*
*.coverage
coverage.xml
htmlcov/
.cache/
.pytest_cache/
.mypy_cache/
.pyre/
.nox/
.tox/
pytest_cache/

# Logs
*.log
*app.log
logs/

# =========================
# Secretos — NUNCA versionar .env plano
# =========================
# Cualquier .env plano en cualquier subcarpeta
.env
**/.env
**/.env.local
**/.env.cache
**/.env.development
**/.env.production
# Excepción: plantilla sin valores reales
!.env.example
!config/.env.example
# El cifrado SÍ va al repo (sin él no hay credenciales)
!config/.env.enc

# =========================
# IA / Cowork (contexto de sesión, NO código)
# =========================
# CLAUDE.md SÍ se versiona — es documentación del proyecto
.claude/sessions/
.claude/cache/

# =========================
# Node / Frontend
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.map

# Bloqueos (si NO usas npm/yarn/pnpm en este repo)
package-lock.json
yarn.lock
pnpm-lock.yaml

# =========================
# IDE / OS
# ========================= 
.vscode/
.idea/
*.swp
*.swo
*.code-workspace
.DS_Store
Thumbs.db
desktop.ini

# =========================
# App-specific
# =========================
# Mapas HTML generados por la app (mantén solo los de esta carpeta)
static/maps/*.html
static/maps/*.png
static/datos/* # Si esta carpeta contiene datos generados que no quieres versionar
static/datos/*

# Cache de coordenadas — datos derivados + PII (coordenadas reales de clientes)
# Se genera automáticamente con cada ejecución del mapa. No va al repo.
static/datos/coordinate_cache.json

Pruebas/Resultados M1/**
Pruebas/Resultados M1/*.html
Pruebas/Resultados M1/*.csv

Pruebas/Resultados M2/**
Pruebas/Resultados M2/*.html
Pruebas/Resultados M2/*.csv

Pruebas/Resultados_M2_Test/**
Pruebas/Resultados_M2_Test/*.html
Pruebas/Resultados_M2_Test/*.csv
Claude/**
agente/ejemplos/*.json
agente/vanna_sql/**


# ⚠️ No ignores todo *.html / *.pdf globalmente
# Si necesitas ignorar PDFs de informes, hazlo por carpeta:
# reports/**/*.pdf

# Mantener vendorizadas las libs del editor (NO ignorarlas)
!static/vendor/**
!static/quadrants_editor/**

# Asegura que los GeoJSON del proyecto se versionen
!geojson/**

